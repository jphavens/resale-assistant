# Anthropic API
ANTHROPIC_API_KEY=
# Model ID used by the pipeline and M0 harness. Change here to A/B test models
# against the same testdata — never hardcode a model ID in code.
ANTHROPIC_MODEL=claude-sonnet-4-6

# eBay application keys (client-credentials grant, production environment).
# Taxonomy API (category + aspect lookups) and Browse API (M0 groundtruth only).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# SQLite database file path (mounted as a volume in Docker Compose).
DATABASE_PATH=./data/resale_assistant.db
